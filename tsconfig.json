{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "strict": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "resolveJsonModule": true
  },
  "include": ["src", "tests", "vite.config.ts", "api", "scripts"]
}
